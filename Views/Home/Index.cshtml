@model TechMove.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-8">

    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8">

        <div class="flex items-center justify-between">

            <div>
                <h1 class="text-4xl font-bold text-slate-900">
                    Welcome back, Admin 👋
                </h1>

                <p class="text-slate-500 mt-2 text-lg">
                    Here's what's happening in your logistics system today.
                </p>
            </div>

            <div class="hidden md:block">
                <div class="bg-slate-100 px-4 py-3 rounded-2xl text-sm text-slate-600">
                    TechMove Enterprise System
                </div>
            </div>

        </div>

    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 hover:shadow-md transition">

            <div class="flex items-center justify-between">

                <div>
                    <p class="text-slate-500 text-sm font-medium">
                        Clients
                    </p>

                    <h2 class="text-4xl font-bold mt-2 text-slate-900">
                        @Model.TotalClients
                    </h2>
                </div>

                <div class="w-14 h-14 rounded-2xl bg-indigo-100 flex items-center justify-center text-2xl">
                    👥
                </div>

            </div>

            <p class="mt-4 text-slate-500 text-sm">
                Manage logistics clients and regional information.
            </p>

            <a asp-controller="Clients"
               asp-action="Index"
               class="inline-block mt-6 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-3 rounded-xl text-sm font-semibold transition">
                View Clients
            </a>

        </div>

        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 hover:shadow-md transition">

            <div class="flex items-center justify-between">

                <div>
                    <p class="text-slate-500 text-sm font-medium">
                        Contracts
                    </p>

                    <h2 class="text-4xl font-bold mt-2 text-slate-900">
                        @Model.TotalContracts
                    </h2>
                </div>

                <div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center text-2xl">
                    📄
                </div>

            </div>

            <p class="mt-4 text-slate-500 text-sm">
                Upload agreements and manage contract workflows.
            </p>

            <a asp-controller="Contracts"
               asp-action="Index"
               class="inline-block mt-6 bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-3 rounded-xl text-sm font-semibold transition">
                View Contracts
            </a>

        </div>

        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-6 hover:shadow-md transition">

            <div class="flex items-center justify-between">

                <div>
                    <p class="text-slate-500 text-sm font-medium">
                        Service Requests
                    </p>

                    <h2 class="text-4xl font-bold mt-2 text-slate-900">
                        @Model.TotalServiceRequests
                    </h2>
                </div>

                <div class="w-14 h-14 rounded-2xl bg-amber-100 flex items-center justify-center text-2xl">
                    🚚
                </div>

            </div>

            <p class="mt-4 text-slate-500 text-sm">
                Track international logistics and currency conversion.
            </p>

            <a asp-controller="ServiceRequests"
               asp-action="Index"
               class="inline-block mt-6 bg-amber-500 hover:bg-amber-600 text-white px-5 py-3 rounded-xl text-sm font-semibold transition">
                View Requests
            </a>

        </div>

    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-3xl p-6">

        <div class="flex items-start gap-4">

            <div class="text-3xl">
                ℹ️
            </div>

            <div>
                <h3 class="font-bold text-blue-900 text-lg">
                    Workflow Rules
                </h3>

                <p class="text-blue-700 mt-1">
                    Service Requests cannot be created for Expired or On Hold Contracts.
                </p>
            </div>

        </div>

    </div>

</div>