@model IEnumerable<TechMove.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="space-y-6">

    <!-- Header -->
    <div class="flex items-center justify-between">

        <div>
            <h1 class="text-3xl font-bold text-slate-900">
                Contracts
            </h1>

            <p class="text-slate-500 mt-1">
                Create, filter and manage signed client contracts.
            </p>
        </div>

        <a asp-action="Create"
           class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-3 rounded-xl text-sm font-semibold shadow-sm transition">
            + New Contract
        </a>

    </div>

    <!-- Search Filter -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm p-6">

        <form method="get"
              class="grid grid-cols-1 md:grid-cols-4 gap-5 items-end">

            <!-- Status -->
            <div>

                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Status
                </label>

                <select
                    name="statusSearch"
                    class="w-full h-12 rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-700 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none">

                    <option value="">All Statuses</option>
                    <option value="pending">Pending</option>
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="On Hold">On Hold</option>

                </select>

            </div>

            <!-- Start Date -->
            <div>

                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    Start Date
                </label>

                <input
                    type="date"
                    name="startDate"
                    class="w-full h-12 rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-700 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none" />

            </div>

            <!-- End Date -->
            <div>

                <label class="block text-sm font-semibold text-slate-700 mb-2">
                    End Date
                </label>

                <input
                    type="date"
                    name="endDate"
                    class="w-full h-12 rounded-xl border border-slate-300 bg-white px-4 text-sm text-slate-700 shadow-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none" />

            </div>

            <!-- Buttons -->
            <div class="flex gap-3">

                <button
                    type="submit"
                    class="h-12 bg-indigo-600 hover:bg-indigo-700 text-white px-6 rounded-xl text-sm font-semibold transition">

                    Search

                </button>

                <a
                    asp-action="Index"
                    class="h-12 bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 rounded-xl text-sm font-semibold transition flex items-center justify-center">

                    Reset

                </a>

            </div>

        </form>

    </div>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-3xl p-6">

            No contracts found for the selected filter criteria.

        </div>
    }
    else
    {
        <!-- Contracts Table -->
        <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">

            <table class="w-full text-sm">

                <thead class="bg-slate-50 border-b border-slate-200">

                    <tr>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            Start Date
                        </th>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            End Date
                        </th>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            Status
                        </th>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            Service Level
                        </th>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            Agreement
                        </th>

                        <th class="text-left px-6 py-4 font-semibold text-slate-600">
                            Client
                        </th>

                        <th class="text-right px-6 py-4 font-semibold text-slate-600">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody class="divide-y divide-slate-100">

                    @foreach (var item in Model)
                    {
                        var statusClass = item.Status?.ToLower() switch
                        {
                            "active" => "bg-green-100 text-green-700",
                            "pending" => "bg-yellow-100 text-yellow-700",
                            "expired" => "bg-red-100 text-red-700",
                            "on hold" => "bg-orange-100 text-orange-700",
                            _ => "bg-slate-100 text-slate-700"
                        };

                        <tr class="hover:bg-slate-50 transition">

                            <!-- Start Date -->
                            <td class="px-6 py-4 text-slate-600">
                                @item.StartDate.ToString("yyyy/MM/dd")
                            </td>

                            <!-- End Date -->
                            <td class="px-6 py-4 text-slate-600">
                                @item.EndDate.ToString("yyyy/MM/dd")
                            </td>

                            <!-- Status -->
                            <td class="px-6 py-4">

                                <span class="px-3 py-1 rounded-full text-xs font-semibold @statusClass">

                                    @item.Status

                                </span>

                            </td>

                            <!-- Service Level -->
                            <td class="px-6 py-4 text-slate-600">
                                @item.ServiceLevel
                            </td>

                            <!-- PDF -->
                            <td class="px-6 py-4">

                                @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                                {
                                    <a href="@item.AgreementFilePath"
                                       download
                                       class="text-indigo-600 hover:text-indigo-800 font-medium">

                                        Download PDF

                                    </a>
                                }

                            </td>

                            <!-- Client -->
                            <td class="px-6 py-4 text-slate-600">
                                @item.Client?.Name
                            </td>

                            <!-- Actions -->
                            <td class="px-6 py-4 text-right space-x-3">

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="text-indigo-600 hover:text-indigo-800 font-medium">

                                    Edit

                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="text-slate-600 hover:text-slate-900 font-medium">

                                    Details

                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="text-red-600 hover:text-red-800 font-medium">

                                    Delete

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>