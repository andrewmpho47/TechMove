@model TechMove.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <h1 class="text-3xl font-bold text-red-700">Delete Client</h1>
        <p class="text-slate-500 mt-1">Confirm that you want to delete this client.</p>
    </div>

    <div class="bg-white border border-red-200 rounded-3xl shadow-sm p-8">

        <div class="bg-red-50 border border-red-200 text-red-700 rounded-2xl p-4 mb-6">
            Are you sure you want to delete this client? This action cannot be undone.
        </div>

        <dl class="space-y-5">

            <div>
                <dt class="text-sm font-semibold text-slate-500">Name</dt>
                <dd class="text-lg font-medium text-slate-900 mt-1">@Model?.Name</dd>
            </div>

            <div>
                <dt class="text-sm font-semibold text-slate-500">Contact Details</dt>
                <dd class="text-lg font-medium text-slate-900 mt-1">@Model?.ContactDetails</dd>
            </div>

            <div>
                <dt class="text-sm font-semibold text-slate-500">Region</dt>
                <dd class="text-lg font-medium text-slate-900 mt-1">@Model?.Region</dd>
            </div>

        </dl>

        <form asp-action="Delete" class="flex gap-3 mt-8">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-xl text-sm font-semibold">
                Delete
            </button>

            <a asp-action="Index" class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-3 rounded-xl text-sm font-semibold">
                Cancel
            </a>
        </form>

    </div>

</div>