@model TechMove.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <h1 class="text-3xl font-bold text-slate-900">Create Client</h1>
        <p class="text-slate-500 mt-1">Add a new logistics client.</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm p-8">

        <form asp-action="Create" class="space-y-5">

            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div>
                <label asp-for="Name" class="block text-sm font-semibold text-slate-700 mb-2"></label>
                <input asp-for="Name" class="w-full h-12 rounded-xl border border-slate-300 px-4 text-sm outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500" />
                <span asp-validation-for="Name" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="ContactDetails" class="block text-sm font-semibold text-slate-700 mb-2"></label>
                <input asp-for="ContactDetails" class="w-full h-12 rounded-xl border border-slate-300 px-4 text-sm outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500" />
                <span asp-validation-for="ContactDetails" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Region" class="block text-sm font-semibold text-slate-700 mb-2"></label>
                <input asp-for="Region" class="w-full h-12 rounded-xl border border-slate-300 px-4 text-sm outline-none focus:ring-2 focus:ring-indigo-200 focus:border-indigo-500" />
                <span asp-validation-for="Region" class="text-red-600 text-sm"></span>
            </div>

            <div class="flex gap-3 pt-4">
                <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl text-sm font-semibold">
                    Save Client
                </button>

                <a asp-action="Index" class="bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-3 rounded-xl text-sm font-semibold">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}