<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechMove</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-slate-50 text-slate-900">

    <div class="min-h-screen flex">

        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-slate-200 min-h-screen hidden md:flex md:flex-col">

            <div class="px-6 py-6 border-b border-slate-100">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-2">
                    <div class="w-9 h-9 rounded-xl bg-indigo-600 text-white flex items-center justify-center font-bold">
                        T
                    </div>
                    <span class="text-xl font-bold text-slate-900">
                        TechMove
                    </span>
                </a>
            </div>

            <nav class="flex-1 px-4 py-6 space-y-2">

                <a asp-controller="Home" asp-action="Index"
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700">
                    Dashboard
                </a>

                <a asp-controller="Clients" asp-action="Index"
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700">
                    Clients
                </a>

                <a asp-controller="Contracts" asp-action="Index"
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700">
                    Contracts
                </a>

                <a asp-controller="ServiceRequests" asp-action="Index"
                       class="flex items-center px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700">
                    Service Requests
                </a>

            </nav>

            <div class="px-6 py-4 text-xs text-slate-400 border-t border-slate-100">
                © 2026 TechMove
            </div>

        </aside>

        <!-- Main Area -->
        <div class="flex-1 flex flex-col">

            <!-- Top Bar -->
            <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6">

                <div>
                    <h2 class="text-sm font-semibold text-slate-500">
                        Enterprise Logistics System
                    </h2>
                </div>

                <div class="flex items-center gap-3">
                    <div
                        class="w-9 h-9 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold">
                        AU
                    </div>
                    <span class="text-sm font-medium text-slate-700">
                        Admin User
                    </span>
                </div>

            </header>

            <!-- Mobile Nav -->
            <div class="md:hidden bg-white border-b border-slate-200 px-4 py-3 flex gap-3 overflow-x-auto">
                <a asp-controller="Home" asp-action="Index" class="text-sm font-medium text-slate-700">Dashboard</a>
                <a asp-controller="Clients" asp-action="Index" class="text-sm font-medium text-slate-700">Clients</a>
                <a asp-controller="Contracts" asp-action="Index"
                   class="text-sm font-medium text-slate-700">Contracts</a>
                <a asp-controller="ServiceRequests" asp-action="Index"
                   class="text-sm font-medium text-slate-700">Service Requests</a>
            </div>

            <!-- Page Content -->
            <main class="p-6">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-5 py-4 rounded-2xl shadow-sm">
                        <span class="font-semibold">
                            Success:
                        </span>

                        @TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-5 py-4 rounded-2xl shadow-sm">
                        <span class="font-semibold">
                            Error:
                        </span>

                        @TempData["ErrorMessage"]
                    </div>
                }

                @RenderBody()

            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>